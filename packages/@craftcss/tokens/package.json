{
  "name": "@craftcss/tokens",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src/index.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./src/index.css"
  },
  "scripts": {
    "generate:css": "tsx src/scripts/generate-css.ts",
    "build": "pnpm run generate:css && tsc -p tsconfig.json",
    "dev": "pnpm run generate:css && tsc -p tsconfig.json --watch",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0 && stylelint \"src/**/*.css\"",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "tsx": "^4.20.3"
  }
}
